# Copy this file to .env for local development. Never commit your real .env.
# On Railway, set these in the service's Variables tab instead.

# Required: your Anthropic API key (starts with sk-ant-...)
ANTHROPIC_API_KEY=your-key-here

# Optional: override the model. Defaults to claude-sonnet-4-6.
# Use claude-haiku-4-5-20251001 for lower cost on high volume.
CLAUDE_MODEL=claude-sonnet-4-6
